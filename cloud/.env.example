# Memento-X Cloud 环境变量模板
# 复制此文件为 .env 并填入实际值

# 数据库
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/memento

# JWT
JWT_SECRET_KEY=your-secret-key-change-me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# 阿里云通义千问
DASHSCOPE_API_KEY=sk-your-api-key

# 服务
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=*
