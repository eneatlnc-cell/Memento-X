# 阿里百炼 通义千问 API
DASHSCOPE_API_KEY=sk-ws-H.EMXXRDH.P4jb.MEYCIQC7t39_eao_QRzteQDDy5QIXXcbaVvhmxQrSOCk8wtgvwIhALfl6J9ycsIZmTmQRJEGHXjTSeTYHZAmadsLCEWAa-VB

# 意图理解引擎
INTENT_MODEL=qwen-vl-pro
